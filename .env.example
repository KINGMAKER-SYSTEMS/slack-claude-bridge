# Required Slack credentials (see README setup)
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=xoxb-...
SLACK_BOT_USER_ID=U0...

# Comma-separated Slack user IDs allowed to mention the bot.
# Anyone not on this list is silently ignored.
ALLOWED_USER_IDS=U0XXXXXXXXX

# Server config
PORT=3737
SESSIONS_FILE=./data/sessions.json
LOG_FILE=./data/bridge.log

# Path to your operator-specific system prompt for Claude.
# Copy prompts/system.example.md → prompts/system.md and customize.
SYSTEM_PROMPT_FILE=./prompts/system.md

# Token gate for /dashboard and /dashboard.json over the public tunnel.
# Leave blank to allow only loopback (localhost) access.
# Set to a random string and pass via ?token=... or Authorization: Bearer.
DASHBOARD_TOKEN=

# Optional MCP tokens — bot works without these, just won't have those tools.
# When either is present, the corresponding MCP server is wired in at boot.
# When missing, the server is skipped and a warning is logged.
# Restart the bridge after adding (`lsof -ti:3737 | xargs kill -9`).

# Linear personal API key. linear.app → Settings → Account → API → Create
# personal API key. Format: `lin_api_...`. Enables Linear ticket
# read/write tools (`mcp__linear__*`).
LINEAR_API_KEY=

# Notion internal integration token. notion.so/my-integrations → New
# integration → copy "Internal Integration Token". Format: `secret_...` or
# `ntn_...`. Remember to share the relevant Notion pages with the
# integration (Notion's permission model is per-page, not workspace-wide).
# Enables Notion search/read/write tools (`mcp__notion__*`).
NOTION_TOKEN=

